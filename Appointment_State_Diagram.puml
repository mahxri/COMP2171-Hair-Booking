@startuml Appointment_State_Diagram
!theme plain
hide empty description
title Appointment State Diagram

[*] --> PendingBooking : Client fills booking form\n(Step A: date, time, phone selected)

state PendingBooking {
    PendingBooking:
}

PendingBooking --> SummaryReview : Client redirected to\nbooking_summary view
PendingBooking --> [*] : Session abandoned / expires

state SummaryReview {
    SummaryReview: Client reviews appointment details before final confirmation
}

SummaryReview --> PendingBooking : Client clicks "Edit"\n[Returns to book_service view]

SummaryReview --> Confirmed : Client clicks "Confirm"\n[No time conflict detected]\nAppointment saved to DB\nstatus = 'confirmed'\nConfirmation email sent

SummaryReview --> SummaryReview : Time slot conflict detected\n[Another booking took the same slot]\nError message shown

state Confirmed {
    Confirmed:
}

Confirmed --> Cancelled : Client clicks "Cancel"\n[cancel_appointment view called]\nCancellation email sent

Confirmed --> Completed : Appointment date passes\n[Implicit - date < today]

state Cancelled {
    Cancelled:
}

state Completed {
    Completed:
}

Cancelled --> [*]
Completed --> [*]

@enduml
