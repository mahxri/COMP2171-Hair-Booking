@startuml
!theme plain

' 1. The logged-in Client
object "client1 : User" as client {
  email = "client@example.com"
  name = "John Doe"
  role = "Client"
  is_logged_in = true
}

' 2. The selected Service
object "service1 : Service" as service {
  name = "Precision Haircut"
  duration = "60 mins"
  price = "$45.00"
}

' 3. The Staff Member providing checking/availability
object "staff1 : User" as staff {
  name = "Sarah Stylist"
  role = "Staff"
  working_hours = "09:00 - 17:00"
}

' 4. The saved Appointment (The main post-condition state)
object "newBooking : Appointment" as appointment {
  date = "2026-04-12"
  start_time = "10:30"
  end_time = "11:30"
  status = "Confirmed"
}

' 5. The Confirmation Notification
object "emailAlert : Notification" as notification {
  type = "Email"
  recipient = "client@example.com"
  status = "Sent"
  timestamp = "2026-04-08 20:15:22"
}

' Relationships detailing the flow connections
appointment --> client : " booked by >"
appointment --> service : " includes >"
appointment --> staff : " assigned to >"
notification --> appointment : " confirms >"
notification --> client : " sent to >"

note right of appointment
  **Post-condition met:**
  A valid time slot was selected, 
  and the appointment is securely 
  added to the system.
end note

note right of notification
  **Post-condition met:**
  Booking confirmation is sent.
end note

@enduml
