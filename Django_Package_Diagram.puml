@startuml
!theme plain
left to right direction

package "Hair Booking Application" {
  
  package "salon_booking (Core)" {
    [settings] as settings_py
    [urls (Root)] as root_urls
  }

  package "bookings (App)" {
    
    package "Presentation Layer" {
      [templates (HTML)] as templates
      [forms] as forms_py
    }
    
    package "Business Logic & Controllers" {
      [views] as views_py
      [urls (App)] as app_urls
      [scheduler] as scheduler_py
      [availability] as availability_py
    }
    
    package "Data Access Layer" {
      [models] as models_py
      [admin] as admin_py
    }
  }

  database "SQLite Database" as db
}

' Define dependencies between the packages
root_urls ..> app_urls : " delegates routes to"
app_urls ..> views_py : " triggers"

views_py ..> models_py : " queries & mutates"
views_py ..> templates : " renders context to"
views_py ..> forms_py : " validates"
views_py ..> scheduler_py : " uses"
views_py ..> availability_py : " checks"

scheduler_py ..> models_py : " manages"
availability_py ..> models_py : " reads"

settings_py ..> db : " configures"
models_py --> db : " Django ORM mapping"

@enduml
