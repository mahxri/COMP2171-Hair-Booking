@startuml
!theme plain

' 1. The logged-in Staff Member/Admin
object "admin1 : User" as admin {
  email = "admin@hairsalon.com"
  role = "Admin"
  is_logged_in = true
}

' 2. The Management Panel
object "managePanel : AdminDashboard" as panel {
  current_view = "Service Catalog"
  last_action = "Save Changes"
}

' 3. A newly added Service 
object "service104 : Service" as active_service {
  name = "Keratin Treatment"
  price = "$150.00"
  duration = "90 mins"
  is_active = true
}

' 4. An edited/deactivated Service (Preserving historical records)
object "service101 : Service" as old_service {
  name = "Basic Trimming (Old Pricing)"
  price = "$20.00"
  duration = "30 mins"
  is_active = false
  deactivation_date = "2026-04-08"
}

' Relationships
admin --> panel : " accesses & edits >"
panel --> active_service : " creates / updates >"
panel --> old_service : " deactivates >"

note bottom of active_service
  **Post-condition met:**
  Service catalog is updated with
  new details for client access.
end note

note bottom of old_service
  **Post-condition met:**
  Historical records are preserved
  by setting 'is_active = false' 
  instead of deleting.
end note

@enduml
