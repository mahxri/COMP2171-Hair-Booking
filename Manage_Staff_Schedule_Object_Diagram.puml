@startuml Manage_Staff_Schedule_Object_Diagram
!theme plain
hide empty description
title Object Diagram: Manage Staff Schedule

' Actor / User Instance
object "staffMember : User" as staff {
    id = 1
    username = "lasheka_admin"
    is_staff = True
}

' View Controller
object "staff_working_hours : View" as schedule_view {
    url = "/staff/working-hours/"
    method = "GET / POST"
}

' Helper Function
object "initializer : Function" as helper {
    name = "_ensure_default_staff_schedule(user)"
}

' Database Model Instances 
' (Showing a working day and an off day as examples)
object "mondaySchedule : StaffDaySchedule" as schedule_mon {
    id = 45
    weekday = 0 (Monday)
    is_working = True
    opens_at = "10:00"
    closes_at = "18:00"
    user_id = 1
}

object "tuesdayOff : StaffDaySchedule" as schedule_tue {
    id = 46
    weekday = 1 (Tuesday)
    is_working = False
    opens_at = null
    closes_at = null
    user_id = 1
}

' Downstream Module Affected
object "bookings.availability : Module" as availability_logic {
    function = "is_slot_allowed_by_staff_hours()"
    function = "bookable_slot_labels_for_date()"
}

' Flow Connections
staff ..> schedule_view : "1. Navigates to dashboard (GET)"
schedule_view ..> helper : "2. Calls to ensure 7 rows exist"

staff ..> schedule_view : "3. Modifies hours & blocks time (POST)"
schedule_view ..> schedule_mon : "4. Updates attributes"
schedule_view ..> schedule_tue : "4. Updates attributes (is_working=False)"

schedule_view ..> schedule_mon : "5. Saves via objects.bulk_update()"
schedule_view ..> schedule_tue : "5. Saves via objects.bulk_update()"

schedule_mon ..> availability_logic : "6. Read by booking module"
schedule_tue ..> availability_logic : "6. Read by booking module"

@enduml
