@startuml Service_Catalog_Object_Diagram
!theme plain

' 1. The Client interacting with the catalog
object "client1 : User" as client {
  email = "client@example.com"
  role = "Client"
  status = "Active"
}

' 2. The Service Catalog View (representing the UI)
object "catalogView : ServiceCatalogPage" as view {
  display_mode = "grid"
  is_loaded = true
  items_shown = 2
}

' 3. Instances of Services available for booking
object "service1 : Service" as haircut {
  service_id = 101
  name = "Box Braids"
  description = "Three-strand plaits divided by small, square-shaped"
  price = "$5000.00"
  duration = "120 mins"
  is_active = true
}

object "service2 : Service" as coloring {
  service_id = 102
  name = "Women's Hair Coloring"
  description = "Full hair coloring with deep conditioning treatment."
  price = "$120.00"
  duration = "120 mins"
  is_active = true
}

' Relationships
client --> view : " browses >"
view *-- haircut : " displays >"
view *-- coloring : " displays >"

note right of view
  **Post-condition met:**
  Client can see available active services 
  with descriptions, pricing, and duration,
  and is able to select one for booking.
end note

@enduml
