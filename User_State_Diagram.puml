@startuml User_State_Diagram
!theme plain
hide empty description
title User Account State Diagram

[*] --> Unregistered : New visitor arrives at site

state Unregistered {
    Unregistered :
}

Unregistered --> Registered : Submits registration form\n[register_request view]\nCustomUserCreationForm valid\nUser saved to DB\nAuto-logged in via login(request, user)

state Registered {
    Registered :
}

Registered --> LoggedIn : Submits login form\n[Django built-in auth]\n[Credentials valid]

Registered --> Registered : Login attempted\n[Invalid credentials]\nError shown

state LoggedIn {
    LoggedIn :
}

LoggedIn --> StaffLoggedIn : [user.is_staff = True\nOR user.is_superuser = True]

state StaffLoggedIn {
    StaffLoggedIn :
}

LoggedIn --> LoggedOut : Clicks "Logout"\n[Django built-in auth logout]

StaffLoggedIn --> LoggedOut : Clicks "Logout"

state LoggedOut {
    LoggedOut :
}

LoggedOut --> LoggedIn : Logs back in\n[Credentials valid]
LoggedOut --> [*] : Leaves the site

@enduml
