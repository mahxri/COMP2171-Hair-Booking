@startuml View_Appointment_Reports_Object_Diagram
!theme plain
hide empty description
title Object Diagram: View Appointment Reports

' 1. Logged in Staff Member
object "admin1 : User" as admin {
  email = "manager@hairsalon.com"
  role = "Admin"
  is_logged_in = true
}

' 2. The Panel they are using
object "reportsPanel : DashboardView" as panel {
  active_tab = "Appointments Report"
  output_format = "PDF Download"
}

' 3. The Query Parameters applied
object "filterSettings : ReportQuery" as query {
  start_date = "2026-04-01"
  end_date = "2026-04-30"
  service_type = "All"
}

' 4. The raw data backing the report
object "appData1 : Appointment" as app1 {
  status = "Completed"
  date = "2026-04-05"
}

object "appData2 : Appointment" as app2 {
  status = "Completed"
  date = "2026-04-08"
}

' 5. The final generated report document
object "monthlySummary : ReportDocument" as report {
  title = "April 2026 Bookings"
  total_appointments = 142
  total_revenue = "$1,000,000"
  generated_at = "2026-04-08 21:00"
  is_ready_for_download = true
}

' Relationships
admin --> panel : " accesses & reviews >"
panel *-- query : " applies parameters >"
query --> report : " generates >"
report --> app1 : " aggregates data from >"
report --> app2 : " aggregates data from >"

note right of report
  **Post-condition met:**
  Staff has access to structured appointment
  reports based on applied filters, 
  ready for download and analysis.
end note

@enduml
